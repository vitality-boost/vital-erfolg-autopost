name: vital.erfolg Auto-Post

on:
  schedule:
    # GitHub-Cron laeuft in UTC.
    # 05:00 UTC = 07:00 Sommerzeit (CEST) / 06:00 Winterzeit (CET).
    - cron: "0 5 * * *"
  workflow_dispatch: {}   # erlaubt manuellen Start per Knopf im Actions-Tab

permissions:
  contents: write         # noetig, damit der Job Bilder + Queue zurueckschreiben darf

concurrency:
  group: vital-autopost
  cancel-in-progress: false

jobs:
  post:
    runs-on: ubuntu-latest
    steps:
      - name: Repo auschecken
        uses: actions/checkout@v4

      - name: Python einrichten
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Schriften installieren
        run: sudo apt-get update && sudo apt-get install -y fonts-liberation2

      - name: Abhaengigkeiten installieren
        run: pip install -r requirements.txt

      - name: Einen Post veroeffentlichen
        env:
          COMPOSIO_API_KEY: ${{ secrets.COMPOSIO_API_KEY }}
          COMPOSIO_USER_ID: ${{ secrets.COMPOSIO_USER_ID }}
        run: python autopost.py
